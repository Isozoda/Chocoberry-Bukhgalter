{
  "expo": {
    "name": "Choco Berry",
    "slug": "chocoberry-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8593C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chocoberry.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8593C"
      },
      "package": "com.chocoberry.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "chocoberry",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        { "backgroundColor": "#E8593C" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
