generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(uuid())
  email              String                 @unique
  name               String
  passwordHash       String
  role               Role                   @default(ADMIN)
  currency           String                 @default("TJS")
  language           String                 @default("tg")
  isActive           Boolean                @default(true)
  telegramChatId     String?                @unique
  telegramLinked     Boolean                @default(false)
  telegramLinkedAt   DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  business           Business?
  dailyReports       DailyReport[]
  employees          Employee[]
  telegramNotifications TelegramNotification[]
}

model TelegramNotification {
  id        String   @id @default(uuid())
  userId    String
  chatId    String
  type      String
  message   String
  sentAt    DateTime @default(now())
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([chatId, isRead])
}

model Business {
  id                String                 @id @default(uuid())
  userId            String                 @unique
  name              String
  type              BusinessType           @default(FOOD)
  address           String?
  phone             String?
  currency          String                 @default("TJS")
  bonusPercent      Decimal                @default(2.0) @db.Decimal(5, 2)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  Attendance        Attendance[]
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashbox           Cashbox?
  categories        Category[]
  dailyReports      DailyReport[]
  employees         Employee[]
  expenses          Expense[]
  transactions      FinancialTransaction[]
  fines             Fine[]
  funds             Fund[]
  fundTxs           FundTransaction[]
  inventoryItems    InventoryItem[]
  inventoryTxs      InventoryTransaction[]
  products          Product[]
  sales             Sale[]
  suppliers         Supplier[]
  supplierPurchases SupplierPurchase[]
  fixedExpenses     FixedExpense[]
  telegramReports   TelegramDailyReport[]
  aiMessages        AiMessage[]
}

model Supplier {
  id         String                 @id @default(uuid())
  businessId String
  name       String
  type       SupplierType           @default(FRUIT)
  phone      String?
  notes      String?
  isActive   Boolean                @default(true)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  business   Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  prices     SupplierPriceHistory[]
  purchases  SupplierPurchase[]

  @@unique([businessId, name])
  @@index([businessId, type])
}

model SupplierPriceHistory {
  id              String        @id @default(uuid())
  supplierId      String
  inventoryItemId String
  date            DateTime      @db.Date
  pricePerUnit    Decimal       @db.Decimal(12, 4)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, inventoryItemId, date])
  @@index([inventoryItemId, date])
}

model SupplierPurchase {
  id               String                @id @default(uuid())
  businessId       String
  supplierId       String
  inventoryItemId  String?
  quantity         Decimal               @db.Decimal(12, 4)
  unit             InventoryUnit
  pricePerUnit     Decimal               @db.Decimal(12, 4)
  totalAmount      Decimal               @db.Decimal(12, 2)
  boxCount         Int?
  kgPerBox         Decimal?              @db.Decimal(8, 2)
  forecastCupsBy03 Int?
  forecastCupsBy04 Int?
  notes            String?
  date             DateTime              @default(now())
  createdAt        DateTime              @default(now())
  inventoryTxId    String?               @unique
  business         Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem?        @relation(fields: [inventoryItemId], references: [id])
  inventoryTx      InventoryTransaction? @relation(fields: [inventoryTxId], references: [id])
  supplier         Supplier              @relation(fields: [supplierId], references: [id])

  @@index([businessId, date])
  @@index([supplierId, date])
}

model Category {
  id          String          @id @default(uuid())
  businessId  String
  name        String
  nameRu      String?
  nameTg      String?
  type        TransactionType
  expenseType ExpenseType?
  icon        String?
  color       String?
  isDefault   Boolean         @default(false)
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses    Expense[]

  @@unique([businessId, name])
}

model Product {
  id         String          @id @default(uuid())
  businessId String
  name       String
  nameRu     String?
  nameTg     String?
  cupType    CupType?
  variant    String?
  price      Decimal         @db.Decimal(10, 2)
  cost       Decimal         @default(0) @db.Decimal(10, 2)
  unit       String          @default("piece")
  category   String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  recipe     ProductRecipe[]
  saleItems  SaleItem[]

  @@unique([businessId, name])
  @@index([businessId, cupType])
}

model ProductRecipe {
  id              String        @id @default(uuid())
  productId       String
  inventoryItemId String
  quantity        Decimal       @db.Decimal(10, 4)
  unit            InventoryUnit
  notes           String?
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
}

model InventoryItem {
  id              String                 @id @default(uuid())
  businessId      String
  name            String
  nameRu          String?
  nameTg          String?
  unit            InventoryUnit          @default(PIECE)
  currentStock    Decimal                @default(0) @db.Decimal(14, 4)
  minStockLevel   Decimal                @default(0) @db.Decimal(14, 4)
  avgCost         Decimal                @default(0) @db.Decimal(14, 4)
  category        String?
  cleaningLossPct Decimal                @default(0) @db.Decimal(5, 2)
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  business        Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions    InventoryTransaction[]
  recipes         ProductRecipe[]
  priceHistory    SupplierPriceHistory[]
  purchases       SupplierPurchase[]

  @@unique([businessId, name])
  @@index([businessId, category])
}

model InventoryTransaction {
  id               String            @id @default(uuid())
  businessId       String
  inventoryItemId  String
  type             StockMovement
  quantity         Decimal           @db.Decimal(14, 4)
  unitCost         Decimal           @db.Decimal(14, 4)
  totalCost        Decimal           @db.Decimal(14, 4)
  stockBefore      Decimal           @db.Decimal(14, 4)
  stockAfter       Decimal           @db.Decimal(14, 4)
  reason           String?
  notes            String?
  expenseId        String?           @unique
  saleId           String?
  date             DateTime          @default(now())
  createdAt        DateTime          @default(now())
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expense          Expense?          @relation(fields: [expenseId], references: [id])
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  supplierPurchase SupplierPurchase?

  @@index([businessId, date])
  @@index([inventoryItemId, date])
  @@index([businessId, type])
}

model Sale {
  id            String        @id @default(uuid())
  businessId    String
  saleNumber    String
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  cashAmount    Decimal       @default(0) @db.Decimal(12, 2)
  cardAmount    Decimal       @default(0) @db.Decimal(12, 2)
  cardType      CardType?
  status        SaleStatus    @default(COMPLETED)
  employeeId    String?
  notes         String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items         SaleItem[]

  @@index([businessId, date])
  @@index([businessId, status])
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String?
  name      String
  quantity  Decimal  @db.Decimal(10, 2)
  unitPrice Decimal  @db.Decimal(10, 2)
  cost      Decimal  @default(0) @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(12, 2)
  product   Product? @relation(fields: [productId], references: [id])
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String                @id @default(uuid())
  businessId    String
  categoryId    String?
  expenseType   ExpenseType           @default(VARIABLE)
  amount        Decimal               @db.Decimal(12, 2)
  description   String?
  vendor        String?
  employeeId    String?
  paymentMethod PaymentMethod         @default(CASH)
  isPaid        Boolean               @default(true)
  date          DateTime              @default(now())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  employeePay   EmployeePayment?
  business      Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?             @relation(fields: [categoryId], references: [id])
  employee      Employee?             @relation(fields: [employeeId], references: [id])
  inventoryTx   InventoryTransaction?
}

model FinancialTransaction {
  id          String          @id @default(uuid())
  businessId  String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  referenceId String?
  refType     String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, date])
  @@index([businessId, type])
}

model Employee {
  id                String            @id @default(uuid())
  businessId        String
  userId            String?
  name              String
  role              String
  isOwner           Boolean           @default(false)
  isConsumableBuyer Boolean           @default(false)
  phone             String?
  salary            Decimal           @default(0) @db.Decimal(10, 2)
  salaryType        SalaryType        @default(MONTHLY)
  bonusPercent      Decimal           @default(0) @db.Decimal(5, 2)
  hireDate          DateTime          @default(now())
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  Attendance        Attendance[]
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user              User?             @relation(fields: [userId], references: [id])
  payments          EmployeePayment[]
  expenses          Expense[]
  fines             Fine[]
  shifts            Shift[]
}

model EmployeePayment {
  id          String      @id @default(uuid())
  employeeId  String
  expenseId   String?     @unique
  amount      Decimal     @db.Decimal(10, 2)
  paymentType PaymentType @default(SALARY)
  period      String?
  notes       String?
  paidAt      DateTime    @default(now())
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expense     Expense?    @relation(fields: [expenseId], references: [id])
}

model Shift {
  id          String    @id @default(uuid())
  employeeId  String
  startTime   DateTime
  endTime     DateTime?
  hoursWorked Decimal?  @db.Decimal(5, 2)
  notes       String?
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Fine {
  id         String    @id @default(uuid())
  businessId String
  employeeId String
  amount     Decimal   @db.Decimal(10, 2)
  reason     String
  isApplied  Boolean   @default(false)
  appliedAt  DateTime?
  date       DateTime  @default(now())
  createdAt  DateTime  @default(now())
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isApplied])
}

model Cashbox {
  id          String             @id @default(uuid())
  businessId  String             @unique
  balance     Decimal            @default(0) @db.Decimal(12, 2)
  cardBalance Decimal            @default(0) @db.Decimal(12, 2)
  currency    String             @default("TJS")
  lastUpdated DateTime           @default(now())
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  operations  CashboxOperation[]
}

model CashboxOperation {
  id            String        @id @default(uuid())
  cashboxId     String
  type          CashboxOpType
  amount        Decimal       @db.Decimal(12, 2)
  balanceBefore Decimal       @db.Decimal(12, 2)
  balanceAfter  Decimal       @db.Decimal(12, 2)
  description   String?
  referenceId   String?
  createdAt     DateTime      @default(now())
  cashbox       Cashbox       @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
}

model Fund {
  id           String            @id @default(uuid())
  businessId   String
  type         FundType
  name         String
  balance      Decimal           @default(0) @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions FundTransaction[]

  @@unique([businessId, type])
}

model FundTransaction {
  id         String          @id @default(uuid())
  businessId String
  fundId     String
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  notes      String?
  date       DateTime        @default(now())
  createdAt  DateTime        @default(now())
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fund       Fund            @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, date])
}

model DailyReport {
  id             String              @id @default(uuid())
  businessId     String
  userId         String
  date           DateTime            @db.Date
  totalSales     Decimal             @default(0) @db.Decimal(12, 2)
  cashSales      Decimal             @default(0) @db.Decimal(12, 2)
  cardSales      Decimal             @default(0) @db.Decimal(12, 2)
  extraIncome    Decimal             @default(0) @db.Decimal(12, 2)
  totalIncome    Decimal             @default(0) @db.Decimal(12, 2)
  suppliersTotal Decimal             @default(0) @db.Decimal(12, 2)
  operationalExp Decimal             @default(0) @db.Decimal(12, 2)
  consumablesExp Decimal             @default(0) @db.Decimal(12, 2)
  ownerDraws     Decimal             @default(0) @db.Decimal(12, 2)
  inventoryExp   Decimal             @default(0) @db.Decimal(12, 2)
  totalExpenses  Decimal             @default(0) @db.Decimal(12, 2)
  charityAmount  Decimal             @default(0) @db.Decimal(12, 2)
  remaining      Decimal             @default(0) @db.Decimal(12, 2)
  notes          String?
  isFinalized    Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  draws          DailyOwnerDraw[]
  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id])
  lines          DailyReportLine[]
  suppliers      DailySupplierLine[]

  @@unique([businessId, date])
  @@index([businessId, date])
}

model DailyReportLine {
  id         String      @id @default(uuid())
  reportId   String
  label      String
  amount     Decimal     @db.Decimal(12, 2)
  type       String
  subType    String?
  employeeId String?
  note       String?
  report     DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model DailySupplierLine {
  id         String      @id @default(uuid())
  reportId   String
  supplierId String?
  name       String
  amount     Decimal     @db.Decimal(12, 2)
  report     DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model DailyOwnerDraw {
  id         String      @id @default(uuid())
  reportId   String
  employeeId String?
  ownerName  String
  amount     Decimal     @db.Decimal(12, 2)
  note       String?
  report     DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String           @id @default(uuid())
  businessId  String
  employeeId  String
  date        DateTime         @db.Date
  status      AttendanceStatus @default(PRESENT)
  note        String?
  bonus       Decimal          @default(0) @db.Decimal(10, 2)
  penalty     Decimal          @default(0) @db.Decimal(10, 2)
  overtimePay Decimal          @default(0) @db.Decimal(10, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  Business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([businessId, date])
}

enum Role {
  ADMIN
  CASHIER
}

enum BusinessType {
  FOOD
  RETAIL
  SERVICE
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ExpenseType {
  FIXED
  VARIABLE
  PAYROLL
  OWNER_DRAW
  CONSUMABLE
  COGS
  WASTE
  FUND
  OTHER
}

enum InventoryUnit {
  KG
  GRAM
  LITER
  ML
  PIECE
  BOX
  PACK
  BLOCK
  DOZEN
  TON
}

enum StockMovement {
  IN
  OUT
  ADJUSTMENT
  WASTE
  CLEANING_LOSS
  TRANSFER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  VOID
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum PaymentType {
  SALARY
  ADVANCE
  BONUS
  LUNCH
  FINE
  OWNER_DRAW
  OTHER
}

enum CashboxOpType {
  IN
  OUT
  OPEN
  CLOSE
  ADJUSTMENT
}

enum SupplierType {
  FRUIT
  CHOCOLATE
  PACKAGING
  OTHER
}

enum FundType {
  CHARITY
  RESERVE
  RENOVATION
  EMERGENCY
  TAX_RESERVE
  OTHER
}

enum CupType {
  CUP_300_ML
  CUP_400_ML
  CUP_80SM
  CUP_90SM
  CUP_ICE_CREAM
  OTHER
}

enum CardType {
  DUSHANBE_CITY
  ALIF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  DAY_OFF
  SICK
}

model FixedExpense {
  id         String    @id @default(uuid())
  businessId String
  name       String
  category   String
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("TJS")
  period     String
  dueDate    DateTime
  paidAt     DateTime?
  isPaid     Boolean   @default(false)
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dueDate])
  @@index([businessId, isPaid])
}

model TelegramDailyReport {
  id             String                    @id @default(uuid())
  businessId     String
  date           DateTime                  @db.Date
  openingBalance Decimal                   @db.Decimal(12, 2)
  closingBalance Decimal                   @db.Decimal(12, 2)
  totalExpenses  Decimal                   @db.Decimal(12, 2)
  rawText        String
  source         String                    @default("telegram")
  createdAt      DateTime                  @default(now())
  business       Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items          TelegramDailyReportItem[]

  @@unique([businessId, date])
  @@index([businessId, date])
}

model TelegramDailyReportItem {
  id       String              @id @default(uuid())
  reportId String
  name     String
  amount   Decimal             @db.Decimal(12, 2)
  category String?
  report   TelegramDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model AiMessage {
  id         String   @id @default(uuid())
  businessId String
  role       String   // 'user' or 'ai'
  content    String   @db.Text
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
}
